# ─── Resend email API ────────────────────────────────────────────
# 1. Sign up at https://resend.com
# 2. Create an API key (Settings → API Keys)
# 3. Add & verify your sending domain (Domains → Add Domain)

RESEND_API_KEY=re_your_api_key_here

# The "from" domain you verified with Resend (e.g. andrewhuang.com)
# Until verified, keep "onboarding@resend.dev" in route.ts for testing
RESEND_FROM_DOMAIN=yourdomain.com

# The email address that receives contact form submissions
CONTACT_TO_EMAIL=andrew@yourdomain.com
